<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow plain HTTP to local network IPs (WLED devices are always on LAN) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">192.168.*.*</domain>
    </domain-config>

    <!-- Allow all local/private IP ranges commonly used for WLED -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.*.*.*</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">172.16.*.*</domain>
    </domain-config>

    <!-- Fallback: allow cleartext for any host not matching above -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
